{
	"name": "3d",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"predeploy": "pnpm build",
		"deploy": "gh-pages -d build",
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
