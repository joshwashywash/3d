{
	"name": "3d",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"deploy": "pnpm build && gh-pages -d build -t true",
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --plugin-search-dir . --check .",
		"format": "prettier . --write ."
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^3.1.1",
		"@sveltejs/adapter-static": "^3.0.1",
		"@sveltejs/kit": "^2.5.0",
		"@sveltejs/vite-plugin-svelte": "^3.0.2",
		"@types/three": "^0.161.2",
		"autoprefixer": "^10.4.17",
		"gh-pages": "^6.1.1",
		"postcss": "^8.4.35",
		"prettier": "^3.2.5",
		"prettier-plugin-svelte": "^3.1.2",
		"svelte": "^4.2.10",
		"svelte-check": "^3.6.4",
		"sveltekit-superforms": "^2.3.0",
		"tailwindcss": "^3.4.1",
		"tslib": "^2.6.2",
		"typescript": "^5.3.3",
		"valibot": "^0.28.1",
		"vite": "^5.1.1"
	},
	"type": "module",
	"dependencies": {
		"@threlte/core": "^7.1.0",
		"@threlte/extras": "^8.7.3",
		"camera-controls": "^2.7.4",
		"three": "^0.161.0"
	}
}
